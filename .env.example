# ============================================================
# INTIVOLUTION AI — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to GitHub.
# ============================================================

# ──────────────────────────────────────────
# CLERK AUTHENTICATION
# Get these from: https://dashboard.clerk.dev
# ──────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Clerk redirect URLs (keep as-is unless you change routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ──────────────────────────────────────────
# GOOGLE GEMINI AI
# Get your key from: https://ai.google.dev/
# ──────────────────────────────────────────
NEXT_PUBLIC_GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# ──────────────────────────────────────────
# NEON DATABASE (Serverless PostgreSQL)
# Get your connection string from: https://neon.tech/
# ──────────────────────────────────────────
DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech/dbname?sslmode=require
